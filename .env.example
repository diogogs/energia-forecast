# --- Data sources -----------------------------------------------------------
ENTSOE_API_TOKEN=            # ENTSO-E Transparency Platform token (email-gated; see README)
# Open-Meteo, OMIE, REN Data Hub: no credentials required

# --- Database (Neon Postgres) ------------------------------------------------
DATABASE_URL=                # POOLED connection string (app + ingestion), sslmode=require
DATABASE_URL_DIRECT=         # DIRECT connection string (alembic migrations only)
DATABASE_URL_RO=             # read-only role (API + dashboard) — never a write-capable string

# --- Experiment tracking (DagsHub-hosted MLflow) ------------------------------
MLFLOW_TRACKING_URI=         # https://dagshub.com/<user>/<repo>.mlflow
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=    # DagsHub token

# --- Serving ------------------------------------------------------------------
API_BASE_URL=                # deployed FastAPI URL (health pings / smoke tests)
